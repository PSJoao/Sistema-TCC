<!DOCTYPE html>
<html lang="pt-BR">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="AutoDocs — Plataforma inteligente de automação de documentos Word com preenchimento dinâmico de variáveis.">
    <title>AutoDocs — Automação de Documentos</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="/css/main.css">
</head>

<body>

    {{#if user}}
    <header class="app-header">
        <div class="logo">
            ✦ AutoDocs
        </div>

        <nav class="nav-links">
            <a href="/dashboard">Meus Templates</a>
            <a href="/upload">Geração em Lote</a>

            <div class="nav-user-area">
                <span class="nav-user-name">Olá, <strong>{{user.nome}}</strong></span>
                <a href="/auth/logout" class="nav-logout">Sair</a>
            </div>
        </nav>
    </header>
    {{/if}}

    <main class="main-content">
        {{{body}}}
    </main>

</body>

</html>