<!DOCTYPE html>
<html lang="pt-BR">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Plataforma de Automação de Documentos</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="/css/main.css">
</head>

<body>

    {{#if user}}
    <header class="app-header">
        <div class="logo">
            AutoDocs
        </div>

        <nav class="nav-links">
            <a href="/dashboard">Meus Templates</a>
            <a href="/upload">Geração em Lote</a>

            <div
                style="display: flex; align-items: center; gap: var(--spacing-md); margin-left: var(--spacing-xl); border-left: 1px solid var(--color-border); padding-left: var(--spacing-md);">
                <span style="color: var(--color-text-muted); font-size: 0.9rem;">Olá,
                    <strong>{{user.nome}}</strong></span>
                <a href="/auth/logout" style="color: var(--color-danger); font-size: 0.9rem; font-weight: 600;">Sair</a>
            </div>
        </nav>
    </header>
    {{/if}}

    <main class="main-content">
        {{{body}}}
    </main>

</body>

</html>