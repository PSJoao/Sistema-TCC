<div class="container mt-5">
    <div class="row mb-4">
        <div class="col-md-8">
            <h2 class="fw-bold text-success"><i class="bi bi-check-circle-fill"></i> Documentos Word Gerados!</h2>
            <p class="text-muted">Os seus documentos foram processados. As variáveis foram injetadas e os cálculos
                matemáticos foram realizados diretamente na estrutura nativa do ficheiro.</p>
        </div>
        <div class="col-md-4 text-end">
            <a href="/dashboard" class="btn btn-outline-primary">
                <i class="bi bi-house-door"></i> Voltar ao Dashboard
            </a>
        </div>
    </div>

    {{#each documentos}}
    <div class="card shadow-sm mb-4 border-primary">
        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
            <h5 class="mb-0"><i class="bi bi-file-earmark-word-fill"></i> {{this.titulo}}.docx</h5>
            <span class="badge bg-light text-primary">ID: {{this.idDocumento}}</span>
        </div>
        <div class="card-body bg-light text-center p-5">
            <div class="mb-3">
                <i class="bi bi-file-earmark-zip text-primary" style="font-size: 4rem;"></i>
            </div>
            <p class="card-text fw-semibold">O documento foi gerado com sucesso preservando todas as fontes, margens e
                estilos originais.</p>
            <a href="{{this.arquivoUrl}}" class="btn btn-primary btn-lg" download>
                <i class="bi bi-download"></i> Descarregar Documento Word (.docx)
            </a>
        </div>
    </div>
    {{/each}}
</div>