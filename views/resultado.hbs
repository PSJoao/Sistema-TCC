<div style="max-width: 740px; margin: 0 auto;">
    <div class="resultado-header">
        <span class="resultado-success-icon">✅</span>
        <h1 class="resultado-title">Documentos Gerados!</h1>
        <p class="resultado-subtitle">Os seus documentos foram processados com sucesso. As variáveis foram injetadas e
            os cálculos matemáticos foram realizados diretamente na estrutura nativa do ficheiro Word.</p>
    </div>

    {{#each documentos}}
    <div class="download-card" style="animation-delay: {{@index}}00ms;">
        <div class="download-card-header">
            <span class="download-card-title">
                📄 {{this.titulo}}.docx
            </span>
            <span class="download-card-badge">Word .docx</span>
        </div>
        <div class="download-card-body">
            <span class="download-card-icon">📥</span>
            <p class="download-card-text">
                Documento gerado preservando todas as fontes, margens e estilos originais.
            </p>
            <a href="{{this.arquivoUrl}}" class="btn btn-primary" download>
                ⬇ Descarregar Documento
            </a>
        </div>
    </div>
    {{/each}}

    <div style="text-align: center; margin-top: var(--spacing-xl);">
        <a href="/dashboard" class="btn btn-secondary">
            ← Voltar ao Dashboard
        </a>
    </div>
</div>