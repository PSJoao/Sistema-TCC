<div style="max-width: 740px; margin: 0 auto;">
    <div class="resultado-header">
        <span class="resultado-success-icon"><i class="ph-fill ph-check-circle" style="color: var(--color-success);"></i></span>
        <h1 class="resultado-title">Documentos Gerados Com Sucesso!</h1>
    </div>

    <div class="card card-static download-card"
        style="text-align: center; padding: var(--spacing-2xl) var(--spacing-lg);">
        <div class="download-card-header" style="justify-content: center; margin-bottom: var(--spacing-md);">
            <span class="download-card-title" style="font-size: 1.5rem;">
                Pacote de Documentos (.zip)
            </span>
        </div>
        <div class="download-card-body"
            style="display: flex; flex-direction: column; align-items: center; gap: var(--spacing-lg);">
            <p class="download-card-text" style="font-size: 1.1rem;">
                Os seus <strong>{{documentos.length}}</strong> documentos estão prontos e foram compactados num único
                ficheiro ZIP para facilitar o download.
            </p>
            <a href="{{zipUrl}}" class="btn btn-primary" style="font-size: 1.1rem; padding: 14px 28px;" download>
                <i class="ph ph-download-simple"></i> Baixar Todos os Documentos
            </a>

            <a href="/dashboard" class="btn btn-secondary mt-3">Voltar ao Início</a>
        </div>
    </div>
</div>