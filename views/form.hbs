<div style="max-width: 740px; margin: 0 auto;">
    <div class="dashboard-header" style="margin-bottom: var(--spacing-lg);">
        <div>
            <h1 class="page-title">Preencher Formulário</h1>
            <p class="page-subtitle" style="margin-bottom: 0;">
                Preencha os campos abaixo para gerar os seus documentos.
            </p>
        </div>
    </div>

    {{#if error}}
    <div class="alert alert-error">
        {{error}}
    </div>
    {{/if}}

    {{#if templatesSelecionados.length}}
    <div class="card card-static template-info-box">
        <h4 class="template-info-title">
            {{#if nomeGrupo}}<i class="ph ph-clipboard-text"></i> {{nomeGrupo}} — {{/if}}Templates incluídos:
        </h4>
        <ul class="template-list-inline">
            {{#each templatesSelecionados}}
            <li>
                <span><i class="ph ph-file-text"></i></span> <strong>{{this.titulo}}</strong>
            </li>
            {{/each}}
        </ul>
    </div>
    {{/if}}

    <div class="card card-static">
        <form action="/documentos/gerar" method="POST">
            {{#each templatesSelecionados}}
            <input type="hidden" name="templateIds[]" value="{{this._id}}">
            {{/each}}

            {{#if grupoId}}
            <input type="hidden" name="grupoId" value="{{grupoId}}">
            {{/if}}

            <div style="display: flex; flex-direction: column; gap: var(--spacing-lg);">
                {{#if fields.length}}
                {{#each fields}}
                <div class="form-group" style="margin-bottom: 0;">
                    <label for="field-{{this.campo}}" class="form-label"
                        style="text-transform: uppercase; letter-spacing: 0.5px; font-weight: 600;">
                        {{this.label}}
                    </label>

                    <!-- Botão de Referências -->
                    <div class="field-badges">
                        <button type="button" class="btn btn-secondary btn-sm" style="padding: 4px 8px; font-size: 0.75rem;" 
                            onclick='ModalSystem.showList("Referências: {{this.campo}}", {{{json this.documentos}}})'>
                            Ver Referências
                        </button>
                    </div>

                    <input type="text" id="field-{{this.campo}}" name="valores[{{this.campo}}]" class="form-control"
                        placeholder="{{this.placeholder}}" required style="margin-top: var(--spacing-sm);">
                </div>
                {{/each}}
                {{else}}
                <p style="color: var(--color-text-muted); text-align: center; padding: var(--spacing-lg) 0;">
                    Nenhuma variável dinâmica foi encontrada nos templates selecionados.
                </p>
                {{/if}}
            </div>

            <div class="form-actions">
                <a href="/dashboard" class="btn btn-secondary" style="flex: 1;">Cancelar</a>
                <button type="submit" class="btn btn-primary" style="flex: 2;">
                    Gerar Documentos Finais
                </button>
            </div>
        </form>
    </div>
</div>