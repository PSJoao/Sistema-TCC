<div class="form-container" style="max-width: 700px; margin: 0 auto;">
    <div class="dashboard-header" style="margin-bottom: var(--spacing-lg);">
        <h1 class="page-title">Preencher Formulário Unificado</h1>
        <p class="page-subtitle">Os campos abaixo foram extraídos automaticamente e unificados a partir dos templates
            enviados.</p>
    </div>

    {{#if error}}
    <div
        style="background-color: rgba(255, 71, 87, 0.1); border: 1px solid var(--color-danger); color: var(--color-danger); padding: var(--spacing-sm) var(--spacing-md); border-radius: var(--radius-md); margin-bottom: var(--spacing-md); font-size: 0.9rem; text-align: center;">
        {{error}}
    </div>
    {{/if}}

    <div class="card" style="margin-bottom: var(--spacing-lg); border-left: 4px solid var(--color-primary);">
        <h4 style="margin-bottom: var(--spacing-sm); color: #ffffff;">Templates incluídos neste lote:</h4>
        <ul style="list-style: none; padding-left: 0; color: var(--color-text-muted); font-size: 0.9rem;">
            {{#each templatesSelecionados}}
            <li style="margin-bottom: var(--spacing-xs); display: flex; align-items: center; gap: var(--spacing-sm);">
                <span>📄</span> <strong>{{this.titulo}}</strong>
            </li>
            {{/each}}
        </ul>
    </div>

    <div class="card">
        <form action="/documentos/gerar" method="POST">
            {{#each templatesSelecionados}}
            <input type="hidden" name="templateIds[]" value="{{this._id}}">
            {{/each}}

            <div class="fields-grid" style="display: flex; flex-direction: column; gap: var(--spacing-md);">
                {{#if fields.length}}
                {{#each fields}}
                <div class="form-group">
                    <label for="field-{{this}}" class="form-label"
                        style="text-transform: uppercase; letter-spacing: 0.5px; font-weight: 600;">
                        {{this}}
                    </label>
                    <input type="text" id="field-{{this}}" name="valores[{{this}}]" class="form-control"
                        placeholder="Introduza o valor para {{this}}" required>
                </div>
                {{/each}}
                {{else}}
                <p style="color: var(--color-text-muted); text-align: center; padding: var(--spacing-md) 0;">
                    Nenhuma variável dinâmica foi encontrada ou necessita de preenchimento manual nestes templates.
                </p>
                {{/if}}
            </div>

            <div
                style="display: flex; gap: var(--spacing-md); margin-top: var(--spacing-xl); border-top: 1px solid var(--color-border); padding-top: var(--spacing-lg);">
                <a href="/upload" class="btn btn-secondary" style="flex: 1;">Cancelar</a>
                <button type="submit" class="btn btn-primary" style="flex: 2;">Gerar Documentos Finais</button>
            </div>
        </form>
    </div>
</div>