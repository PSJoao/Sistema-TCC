<div style="max-width: 620px; margin: 0 auto;">
    <div class="dashboard-header" style="margin-bottom: var(--spacing-lg);">
        <div>
            <h1 class="page-title">Geração em Lote</h1>
            <p class="page-subtitle" style="margin-bottom: 0;">Faça o upload de até 100 templates simultâneos para
                mapear e unificar os campos.</p>
        </div>
    </div>

    {{#if error}}
    <div class="alert alert-error">
        {{error}}
    </div>
    {{/if}}

    <div class="card card-static">
        <form action="/templates/upload" method="POST" enctype="multipart/form-data" id="uploadForm">

            <div class="form-group">
                <label for="nomeGrupo" class="form-label">Nome do Template *</label>
                <input type="text" id="nomeGrupo" name="nomeGrupo" class="form-control"
                    placeholder="Ex: Contrato de Prestação de Serviços" required>
            </div>

            <div class="upload-area" id="dropArea">
                <div class="upload-icon">📤</div>
                <h3 class="upload-title">Arraste e solte os arquivos aqui</h3>
                <p class="upload-hint">ou clique para navegar pelos ficheiros</p>
                <p class="upload-formats">Formatos aceites: .docx, .txt</p>
                <input type="file" name="templates" id="fileInput" multiple required style="display: none;"
                    accept=".docx,.txt">
            </div>

            <div id="fileListContainer" class="file-list-container" style="display: none;">
                <h4 class="file-list-header">
                    Ficheiros Selecionados (<span id="fileCount">0</span>/100):
                </h4>
                <ul id="fileList" class="file-list"></ul>
            </div>

            <div style="display: flex; gap: var(--spacing-md);">
                <a href="/dashboard" class="btn btn-secondary" style="flex: 1;">Voltar</a>
                <button type="submit" class="btn btn-primary" id="submitBtn" style="flex: 2;" disabled>
                    Processar Lote
                </button>
            </div>
        </form>
    </div>
</div>

<script>
    const dropArea = document.getElementById('dropArea');
    const fileInput = document.getElementById('fileInput');
    const fileListContainer = document.getElementById('fileListContainer');
    const fileList = document.getElementById('fileList');
    const fileCount = document.getElementById('fileCount');
    const submitBtn = document.getElementById('submitBtn');

    // Despoleta o seletor de ficheiros ao clicar na área
    dropArea.addEventListener('click', () => fileInput.click());

    // Efeitos visuais ao arrastar ficheiros sobre a zona
    ['dragenter', 'dragover'].forEach(eventName => {
        dropArea.addEventListener(eventName, (e) => {
            e.preventDefault();
            dropArea.classList.add('dragover');
        }, false);
    });

    ['dragleave', 'drop'].forEach(eventName => {
        dropArea.addEventListener(eventName, (e) => {
            e.preventDefault();
            dropArea.classList.remove('dragover');
        }, false);
    });

    // Captura os ficheiros largados na zona
    dropArea.addEventListener('drop', (e) => {
        const dt = e.dataTransfer;
        const files = dt.files;
        fileInput.files = files;
        updateFileList(files);
    });

    // Captura a seleção de ficheiros convencional
    fileInput.addEventListener('change', (e) => {
        updateFileList(e.target.files);
    });

    // Atualiza a interface e valida as regras de negócio de lote
    function updateFileList(files) {
        fileList.innerHTML = '';
        const totalFiles = files.length;

        if (totalFiles > 100) {
            alert('Erro: O sistema aceita no máximo 100 templates por lote. Reduza a quantidade de ficheiros.');
            fileInput.value = '';
            fileListContainer.style.display = 'none';
            submitBtn.disabled = true;
            return;
        }

        if (totalFiles > 0) {
            fileCount.textContent = totalFiles;
            fileListContainer.style.display = 'block';
            submitBtn.disabled = false;

            Array.from(files).forEach(file => {
                const li = document.createElement('li');
                li.innerHTML = '<span class="card-doc-icon">📄</span> ' + file.name;
                fileList.appendChild(li);
            });
        } else {
            fileListContainer.style.display = 'none';
            submitBtn.disabled = true;
        }
    }
</script>