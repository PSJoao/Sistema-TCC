<div style="max-width: 620px; margin: 0 auto;">
    <div class="dashboard-header" style="margin-bottom: var(--spacing-lg);">
        <div>
            <h1 class="page-title">Novo Template</h1>
            <p class="page-subtitle" style="margin-bottom: 0;">Faça o upload dos documentos para criar um novo
                template. Você poderá configurar labels e placeholders na próxima etapa.</p>
        </div>
    </div>

    {{#if error}}
    <div class="alert alert-error">
        {{error}}
    </div>
    {{/if}}

    <div class="card card-static">
        <form action="/templates/upload" method="POST" enctype="multipart/form-data" id="uploadForm">

            <div class="form-group">
                <label for="nomeGrupo" class="form-label">Nome do Template *</label>
                <input type="text" id="nomeGrupo" name="nomeGrupo" class="form-control"
                    placeholder="Ex: Contrato de Prestação de Serviços" required>
            </div>

            <div class="upload-area" id="dropArea">
                <div class="upload-icon"><i class="ph ph-upload-simple"></i></div>
                <h3 class="upload-title">Arraste e solte os arquivos aqui</h3>
                <p class="upload-hint">ou clique para navegar pelos ficheiros</p>
                <p class="upload-formats">Formatos aceites: .docx, .txt</p>
                <input type="file" name="templates" id="fileInput" multiple style="display: none;"
                    accept=".docx,.txt">
            </div>

            <div id="fileListContainer" class="file-list-container" style="display: none;">
                <h4 class="file-list-header">
                    Ficheiros Selecionados (<span id="fileCount">0</span>/100):
                </h4>
                <ul id="fileList" class="file-list"></ul>
            </div>

            <div style="display: flex; gap: var(--spacing-md);">
                <a href="/dashboard" class="btn btn-secondary" style="flex: 1;">Voltar</a>
                <button type="submit" class="btn btn-primary" id="submitBtn" style="flex: 2;" disabled>
                    Criar Template
                </button>
            </div>
        </form>
    </div>
</div>

<script src="/scripts/upload.js"></script>