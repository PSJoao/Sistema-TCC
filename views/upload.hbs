<div class="upload-container" style="max-width: 600px; margin: 0 auto;">
    <div class="dashboard-header" style="margin-bottom: var(--spacing-lg);">
        <h1 class="page-title">Geração em Lote</h1>
        <p class="page-subtitle">Faça o upload de até 100 templates simultâneos para mapear e unificar os campos.</p>
    </div>

    {{#if error}}
    <div
        style="background-color: rgba(255, 71, 87, 0.1); border: 1px solid var(--color-danger); color: var(--color-danger); padding: var(--spacing-sm) var(--spacing-md); border-radius: var(--radius-md); margin-bottom: var(--spacing-md); font-size: 0.9rem; text-align: center;">
        {{error}}
    </div>
    {{/if}}

    <div class="card">
        <form action="/templates/upload" method="POST" enctype="multipart/form-data" id="uploadForm">
            <div class="upload-area" id="dropArea">
                <div class="upload-icon">📤</div>
                <h3>Arraste e solte os arquivos aqui</h3>
                <p style="color: var(--color-text-muted); font-size: 0.9rem; margin-top: var(--spacing-sm);">
                    ou clique para navegar pelos ficheiros
                </p>
                <p style="color: var(--color-text-muted); font-size: 0.8rem; margin-top: var(--spacing-xs);">
                    Formatos aceites: .html, .txt, .hbs
                </p>
                <input type="file" name="templates" id="fileInput" multiple required style="display: none;"
                    accept=".docx,.txt">
            </div>

            <div id="fileListContainer" style="display: none; margin-bottom: var(--spacing-lg);">
                <h4 style="margin-bottom: var(--spacing-sm); color: var(--color-primary);">
                    Ficheiros Selecionados (<span id="fileCount">0</span>/100):
                </h4>
                <ul id="fileList"
                    style="list-style: none; max-height: 200px; overflow-y: auto; border: 1px solid var(--color-border); padding: var(--spacing-sm); border-radius: var(--radius-md); background-color: var(--color-background);">
                </ul>
            </div>

            <div style="display: flex; gap: var(--spacing-md);">
                <a href="/dashboard" class="btn btn-secondary" style="flex: 1;">Voltar</a>
                <button type="submit" class="btn btn-primary" id="submitBtn" style="flex: 2;" disabled>Processar
                    Lote</button>
            </div>
        </form>
    </div>
</div>

<script>
    const dropArea = document.getElementById('dropArea');
    const fileInput = document.getElementById('fileInput');
    const fileListContainer = document.getElementById('fileListContainer');
    const fileList = document.getElementById('fileList');
    const fileCount = document.getElementById('fileCount');
    const submitBtn = document.getElementById('submitBtn');

    // Despoleta o seletor de ficheiros ao clicar na área
    dropArea.addEventListener('click', () => fileInput.click());

    // Efeitos visuais ao arrastar ficheiros sobre a zona
    ['dragenter', 'dragover'].forEach(eventName => {
        dropArea.addEventListener(eventName, (e) => {
            e.preventDefault();
            dropArea.classList.add('dragover');
        }, false);
    });

    ['dragleave', 'drop'].forEach(eventName => {
        dropArea.addEventListener(eventName, (e) => {
            e.preventDefault();
            dropArea.classList.remove('dragover');
        }, false);
    });

    // Captura os ficheiros largados na zona
    dropArea.addEventListener('drop', (e) => {
        const dt = e.dataTransfer;
        const files = dt.files;
        fileInput.files = files;
        updateFileList(files);
    });

    // Captura a seleção de ficheiros convencional
    fileInput.addEventListener('change', (e) => {
        updateFileList(e.target.files);
    });

    // Atualiza a interface e valida as regras de negócio de lote
    function updateFileList(files) {
        fileList.innerHTML = '';
        const totalFiles = files.length;

        if (totalFiles > 100) {
            alert('Erro: O sistema aceita no máximo 100 templates por lote. Reduza a quantidade de ficheiros.');
            fileInput.value = '';
            fileListContainer.style.display = 'none';
            submitBtn.disabled = true;
            return;
        }

        if (totalFiles > 0) {
            fileCount.textContent = totalFiles;
            fileListContainer.style.display = 'block';
            submitBtn.disabled = false;

            Array.from(files).forEach(file => {
                const li = document.createElement('li');
                li.textContent = file.name;
                li.style.padding = '6px 10px';
                li.style.borderBottom = '1px solid var(--color-border)';
                li.style.fontSize = '0.85rem';
                li.style.color = 'var(--color-text-main)';
                fileList.appendChild(li);
            });
        } else {
            fileListContainer.style.display = 'none';
            submitBtn.disabled = true;
        }
    }
</script>