<div class="dashboard-header"
    style="display: flex; justify-content: space-between; align-items: center; margin-bottom: var(--spacing-lg); flex-wrap: wrap; gap: var(--spacing-md);">
    <div>
        <h1 class="page-title">Meus Templates</h1>
        <p class="page-subtitle">Faça a gestão dos seus modelos de documentos dinâmicos.</p>
    </div>
    <a href="/upload" class="btn btn-primary">
        + Adicionar Templates
    </a>
</div>

<div class="grid-cards">
    {{#if templates.length}}
    {{#each templates}}
    <div class="card">
        <h3 style="margin-bottom: var(--spacing-sm);">{{this.titulo}}</h3>

        <p style="color: var(--color-text-muted); font-size: 0.9rem; margin-bottom: var(--spacing-md);">
            Adicionado em: {{this.dataCriacao}}
        </p>

        <div style="display: flex; gap: var(--spacing-sm); flex-wrap: wrap;">
            <a href="/documentos/gerar/{{this._id}}" class="btn btn-primary"
                style="flex: 1; padding: 8px 12px; font-size: 0.9rem;">
                Gerar
            </a>

            <a href="/templates/editar/{{this._id}}" class="btn btn-secondary"
                style="padding: 8px 12px; font-size: 0.9rem;">
                Editar
            </a>

            <form action="/templates/excluir/{{this._id}}" method="POST" style="display: inline;"
                onsubmit="return confirm('Tem a certeza que deseja eliminar este template?');">
                <button type="submit" class="btn btn-danger" style="padding: 8px 12px; font-size: 0.9rem;">
                    Excluir
                </button>
            </form>
        </div>
    </div>
    {{/each}}
    {{else}}
    <div class="card" style="grid-column: 1 / -1; text-align: center; padding: 4rem 2rem;">
        <div style="font-size: 3rem; margin-bottom: var(--spacing-md); color: var(--color-border);">📄</div>
        <h3 style="color: var(--color-text-main);">Nenhum template encontrado</h3>
        <p style="color: var(--color-text-muted); margin-bottom: var(--spacing-lg);">Ainda não fez o upload de nenhum
            modelo de documento para o sistema.</p>
        <a href="/upload" class="btn btn-primary">
            Fazer o Primeiro Upload
        </a>
    </div>
    {{/if}}
</div>