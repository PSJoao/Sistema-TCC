<div class="dashboard-header">
    <div>
        <h1 class="page-title">Meus Templates</h1>
        <p class="page-subtitle" style="margin-bottom: 0;">Faça a gestão dos seus modelos de documentos dinâmicos.</p>
    </div>
    <a href="/upload" class="btn btn-primary">
        + Novo Template
    </a>
</div>

<div class="grid-cards">
    {{#if grupos.length}}
    {{#each grupos}}
    <div class="card">
        <div class="card-header-area">
            <h3 class="card-title">{{this.nome}}</h3>
            <div class="card-meta">
                <span class="card-meta-icon">📅</span>
                <span>{{this.dataCriacao}}</span>
                <span class="badge badge-count">{{this.quantidadeDocumentos}} doc(s)</span>
            </div>
        </div>

        <ul class="card-docs-list">
            {{#each this.documentos}}
            <li class="card-doc-item">
                <span class="card-doc-icon">📄</span>
                <span>{{this.titulo}}</span>
            </li>
            {{/each}}
        </ul>

        <div class="card-actions">
            <a href="/documentos/gerar/{{this._id}}" class="btn btn-primary btn-sm" style="flex: 1;">
                ▶ Gerar
            </a>

            <a href="/templates/editar/{{this._id}}" class="btn btn-secondary btn-sm" style="flex: 1;">
                ✏️ Editar
            </a>

            <form action="/templates/excluir/{{this._id}}" method="POST" style="flex: 1; display: contents;"
                onsubmit="return confirm('Tem a certeza que deseja eliminar este template e todos os seus documentos?');">
                <button type="submit" class="btn btn-danger btn-sm" style="width: 100%;">
                    🗑 Excluir
                </button>
            </form>
        </div>
    </div>
    {{/each}}
    {{else}}
    <div class="card card-static empty-state">
        <div class="empty-state-icon">📄</div>
        <h3 class="empty-state-title">Nenhum template encontrado</h3>
        <p class="empty-state-text">Ainda não fez o upload de nenhum modelo de documento para o sistema.</p>
        <a href="/upload" class="btn btn-primary">
            Fazer o Primeiro Upload
        </a>
    </div>
    {{/if}}
</div>