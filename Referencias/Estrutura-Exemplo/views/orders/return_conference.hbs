<div class="page-header">
    <div>
        <h1>Conferência de Devoluções</h1>
    </div>
    <div class="page-header-actions">
        <a href="/pedidos" class="btn btn-outline">Voltar</a>
    </div>
</div>

<div class="container" style="max-width: 800px;">
    
    <section class="card mb-4">
        <div class="card-body">
            <div class="form-group mb-0">
                <label for="returnInput" style="font-size: 1.2rem; font-weight: 700;">Bipar Código (Pack ID / Venda / Nota)</label>
                <div class="scan-input-wrapper" style="display: flex; gap: 10px;">
                    <input type="text" id="returnInput" class="form-control" 
                           placeholder="Aguardando leitura..." autofocus autocomplete="off" 
                           style="font-size: 1.5rem; height: 60px;">
                    <button id="btnClear" class="btn btn-outline" type="button" style="min-width: 100px;">Limpar</button>
                </div>
            </div>
        </div>
    </section>

    <br><br>

    <section id="resultArea" class="card" style="display: none; border-left: 6px solid var(--primary-color);">
        <div class="card-header">
            <h2 class="card-title" style="margin: 0;">Pedido Encontrado</h2>
            <span id="orderNumberDisplay" class="badge" style="font-size: 1rem; background: #e2e8f0; color: #333;"># - </span>
        </div>
        
        <div class="card-body">
            <div class="orders-status-grid" style="grid-template-columns: 1fr 1fr; margin-bottom: 20px;">
                
                <div>
                    <p><strong>Comprador:</strong> <span id="resComprador">-</span></p>
                    <p><strong>Produto:</strong> <span id="resProduto">-</span></p>
                    <p><strong>Pack ID:</strong> <span id="resPackId" style="font-family: monospace; background: #f8fafc; padding: 2px 5px;">-</span></p>
                </div>

                <div>
                    <p><strong>Status Sistema:</strong> <span id="resStatusBucket" class="badge">-</span></p>
                    <p><strong>Situação Devolução:</strong> <span id="resDevHistorico" class="badge" style="font-size: 1rem;">-</span></p>
                </div>
            </div>

            <div id="alreadyResolvedAlert" class="form-error" style="display: none; text-align: center; margin-bottom: 20px;">
                <i class="icon-check-circle"></i> Este pedido já consta como <strong>RESOLVIDO</strong>.
            </div>

            <div id="actionArea" style="text-align: center; padding-top: 20px; border-top: 1px solid #eee;">
                <p class="text-muted mb-3">O pedido está fisicamente conferido e o caso encerrado?</p>
                <button id="btnResolve" class="btn btn-success btn-lg" style="width: 100%; max-width: 400px;">
                    <i class="icon-check"></i> MARCAR COMO RESOLVIDO
                </button>
            </div>
        </div>
    </section>

    <div id="emptyState" class="text-center mt-5 text-muted">
        <i class="icon-search" style="font-size: 4rem; color: var(--border-color); opacity: 0.5;"></i>
        <p class="mt-3">Aguardando bipagem...</p>
    </div>

</div>

<script src="/scripts/return-conference.js"></script>